{
  "name": "openconvert",
  "version": "0.1.0",
  "description": "All in one file converter app",
  "main": "./src/main/main.js",
  "scripts": {
    "dev": "vite dev && electron .",
    "start": "electron .",
    "package-win": "electron-builder -w",
    "package-linux": "electron-builder -l"
  },
  "build": {
    "appId": "com.openconvert.app",
    "win": {
      "icon": "./icons/logo.ico",
      "target": "nsis-web"
    },
    "linux": {
      "target": "appimage"
    },
    "nsisWeb": {
      "allowToChangeInstallationDirectory": true,
      "oneClick": false
    }
  },
  "keywords": [
    "converter",
    "image-converter",
    "video-converter",
    "offline",
    "javascript",
    "electron",
    "hacktoberfest"
  ],
  "author": "utmp",
  "license": "GPL-3.0",
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^6.0.1",
    "vue": "^3.5.13"
  },
  "dependencies": {
    "sqlite3": "^5.1.7"
  }
}
